# === Python bytecode ===
__pycache__/
*.py[cod]

# === Build artifacts (PyInstaller, dist, etc.) ===
build/
dist/
*.spec
!ToonTownMultiTool.spec

# === AppImages or binary blobs ===
*.AppImage

# === macOS system file (ignore if present) ===
.DS_Store

# === AppDir — ignore the binary, keep metadata ===
AppDir/usr/

# === Local Claude Code config / skills (not for GitHub) ===
.claude/

# === Other local agent / editor configs ===
.codex/
.superpowers/
.idea/
.vscode/

# === Editor swap / backup files ===
*.swp
*.swo
*~
*.bak

# === Local release archives (CI publishes the official ones) ===
*.tar.gz
*.zip

# === Python tool caches ===
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# === Virtualenvs ===
.venv/
venv/
env/

# === Python packaging ===
*.egg-info/
*.egg

# === Secrets / env files ===
.env
.env.*
!.env.example

# === OS junk ===
Thumbs.db
desktop.ini

